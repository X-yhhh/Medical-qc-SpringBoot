<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.medical.qc.modules.pacs.persistence.mapper.PacsStudyMapper">

    <resultMap id="PacsStudyCacheResultMap" type="com.medical.qc.modules.pacs.model.PacsStudyCache">
        <id column="id" property="id" />
        <result column="study_instance_uid" property="studyInstanceUid" />
        <result column="patient_id" property="patientId" />
        <result column="patient_name" property="patientName" />
        <result column="gender" property="gender" />
        <result column="age" property="age" />
        <result column="accession_number" property="accessionNumber" />
        <result column="study_date" property="studyDate" />
        <result column="study_time" property="studyTime" />
        <result column="study_description" property="studyDescription" />
        <result column="modality" property="modality" />
        <result column="series_count" property="seriesCount" />
        <result column="image_count" property="imageCount" />
        <result column="body_part" property="bodyPart" />
        <result column="manufacturer" property="manufacturer" />
        <result column="model_name" property="modelName" />
        <result column="image_file_path" property="imageFilePath" />
        <result column="patient_image_path" property="patientImagePath" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <sql id="PacsCacheWhereClause">
        <where>
            <if test="patientId != null and patientId != ''">
                AND p.patient_id = #{patientId}
            </if>
            <if test="patientName != null and patientName != ''">
                AND p.patient_name LIKE CONCAT('%', #{patientName}, '%')
            </if>
            <if test="accessionNumber != null and accessionNumber != ''">
                AND p.accession_number = #{accessionNumber}
            </if>
            <if test="startDate != null">
                AND p.study_date <![CDATA[>=]]> #{startDate}
            </if>
            <if test="endDate != null">
                AND p.study_date <![CDATA[<=]]> #{endDate}
            </if>
        </where>
    </sql>

    <select id="searchStudiesFromCache" resultMap="PacsStudyCacheResultMap">
        SELECT
            p.id,
            p.study_instance_uid,
            p.patient_id,
            p.patient_name,
            NULL AS gender,
            NULL AS age,
            p.accession_number,
            p.study_date,
            p.study_time,
            p.study_description,
            p.modality,
            p.series_count,
            p.image_count,
            p.body_part,
            p.manufacturer,
            p.model_name,
            p.image_file_path,
            NULL AS patient_image_path,
            p.created_at,
            p.updated_at
        FROM pacs_study_cache p
        <include refid="PacsCacheWhereClause" />
        ORDER BY p.study_date DESC, p.study_time DESC
        LIMIT 100
    </select>

    <select id="selectStudiesForSync" resultMap="PacsStudyCacheResultMap">
        SELECT
            p.id,
            p.study_instance_uid,
            p.patient_id,
            p.patient_name,
            NULL AS gender,
            NULL AS age,
            p.accession_number,
            p.study_date,
            p.study_time,
            p.study_description,
            p.modality,
            p.series_count,
            p.image_count,
            p.body_part,
            p.manufacturer,
            p.model_name,
            p.image_file_path,
            NULL AS patient_image_path,
            p.created_at,
            p.updated_at
        FROM pacs_study_cache p
        ORDER BY p.study_date DESC, p.study_time DESC
        LIMIT 1000
    </select>
</mapper>
